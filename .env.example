# OpenAI-like endpoint for postcard generation.
# Put your model proxy URL here. It must accept POST requests compatible with
# OpenAI Chat Completions: { model, messages, temperature, max_tokens }.
#
# Examples:
# VITE_OPENAI_LIKE_API_URL=https://llm-proxy.example.com/v1/chat/completions
# VITE_OPENAI_LIKE_API_URL=http://localhost:8080/v1/chat/completions
VITE_OPENAI_LIKE_API_URL=https://llm-proxy.t-tech.team/v1/chat/completions

# Model name that your proxy expects.
VITE_OPENAI_LIKE_MODEL=tgpt/qwen36-35b-a3b-fp8

# Optional. If set, the app sends Authorization: Bearer <value>.
# Do not commit real keys in .env files.
VITE_OPENAI_LIKE_API_KEY=
